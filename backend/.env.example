# ── App ───────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ── Database ──────────────────────────────────────────────────
# For Docker: use service name 'postgres' as host
DATABASE_URL=postgresql+asyncpg://soil_user:soil_pass@localhost:5432/soil_intelligence

# ── Auth ──────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_generate_a_32_char_random_string
SECRET_KEY=CHANGE_ME_generate_another_32_char_random_string

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.lt"]

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Email (SendGrid) ──────────────────────────────────────────
SMTP_PASSWORD=your_sendgrid_api_key
FROM_EMAIL=noreply@soilintelligence.lt
FROM_NAME=Soil Intelligence

# ── Stripe Payments ───────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── AWS S3 (or MinIO locally) ─────────────────────────────────
AWS_ACCESS_KEY=your_access_key
AWS_SECRET_KEY=your_secret_key
S3_BUCKET=soil-intelligence-reports
S3_REGION=eu-north-1
# For local MinIO: override endpoint in boto3 config

# ── External APIs ─────────────────────────────────────────────
WEATHER_API_KEY=your_openweathermap_key
GOOGLE_MAPS_API_KEY=your_google_maps_key
# WORKIS_API_KEY=your_workis_key
